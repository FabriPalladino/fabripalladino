---
layout: layouts/page.njk
title: "Contact"
description: "Get in touch with Fabrizio Palladino — let's work together."
---
<section class="hero">
  <h1 data-reveal>Let's Work Together</h1>
  <p class="hero__subtitle" data-reveal data-reveal-delay="1">
    Have a project in mind? I'd love to hear about it.
  </p>
</section>

<section class="section section--border">
  <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" data-reveal>
    <input type="hidden" name="form-name" value="contact">
    <p style="display:none;">
      <label>Don't fill this out: <input name="bot-field"></label>
    </p>

    <div class="form__group">
      <label for="name" class="form__label">Name</label>
      <input type="text" id="name" name="name" class="form__input" required>
    </div>

    <div class="form__group">
      <label for="email" class="form__label">Email</label>
      <input type="email" id="email" name="email" class="form__input" required>
    </div>

    <div class="form__group">
      <label for="message" class="form__label">Message</label>
      <textarea id="message" name="message" class="form__textarea" required></textarea>
    </div>

    <button type="submit" class="form__button">Send Message</button>
  </form>
</section>

<section class="section section--border">
  <h2 data-reveal>Other Ways to Reach Me</h2>
  <div class="grid" style="margin-top: var(--fp-space-md);">
    <div class="card" data-reveal data-reveal-delay="1">
      <h3 class="card__title">LinkedIn</h3>
      <p class="card__text"><a href="https://www.linkedin.com/in/fabripalladino/" target="_blank" rel="noopener noreferrer">linkedin.com/in/fabripalladino</a></p>
    </div>
    <div class="card" data-reveal data-reveal-delay="2">
      <h3 class="card__title">GitHub</h3>
      <p class="card__text"><a href="https://github.com/fabripalladino" target="_blank" rel="noopener noreferrer">github.com/fabripalladino</a></p>
    </div>
    <div class="card" data-reveal data-reveal-delay="3">
      <h3 class="card__title">Email</h3>
      <p class="card__text"><a href="mailto:{{ meta.email }}">{{ meta.email }}</a></p>
    </div>
  </div>
</section>
