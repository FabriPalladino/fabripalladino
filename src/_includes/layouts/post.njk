---
layout: layouts/base.njk
---
<article class="container">
  <header class="article__header">
    <div class="article__meta">
      <time datetime="{{ date | readableDate }}">{{ date | readableDate }}</time>
    </div>
    <h1>{{ title }}</h1>
    {% if description %}
      <p class="hero__subtitle">{{ description }}</p>
    {% endif %}
  </header>

  <div class="article__content">
    {{ content | safe }}
  </div>

  <a href="/blog/" class="article__back cta-link" style="flex-direction: row-reverse;">
    <span>Back to blog</span>
  </a>
</article>
